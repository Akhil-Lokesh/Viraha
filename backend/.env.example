NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://viraha:viraha_dev_password@localhost:5433/viraha_dev

JWT_SECRET=change-this-to-a-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-secret-key

CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 (optional — falls back to local disk)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# Redis (optional — caching disabled if not set)
REDIS_URL=redis://localhost:6379

# Sentry (optional)
# SENTRY_DSN=

# Google Places API (optional — location autocomplete)
# GOOGLE_PLACES_API_KEY=

# Resend (optional — email sending)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@viraha.app
